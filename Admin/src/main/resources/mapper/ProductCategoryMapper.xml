<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ahead.distribution.admin.mapper.ProductCategoryMapper">

    <resultMap id="CategoryResultMap" type="ProductCategory">
        <id property="id" column="id"/>
        <result property="parentId" column="parent_id"/>
        <result property="name" column="name"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="icon" column="icon"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findAll" resultMap="CategoryResultMap">
        SELECT * FROM product_categories ORDER BY sort_order ASC, id ASC
    </select>

    <select id="findById" resultMap="CategoryResultMap">
        SELECT * FROM product_categories WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product_categories (parent_id, name, sort_order, icon, status, created_at, updated_at)
        VALUES (#{parentId}, #{name}, #{sortOrder}, #{icon}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update">
        UPDATE product_categories
        <set>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="name != null">name = #{name},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="status != null">status = #{status},</if>
            updated_at = #{updatedAt}
        </set>
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM product_categories WHERE id = #{id}
    </delete>

</mapper>
