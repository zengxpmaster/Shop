<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ahead.distribution.admin.mapper.OrderProductMapper">

    <resultMap id="OrderProductResultMap" type="OrderProduct">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="productId" column="product_id"/>
        <result property="productSkuId" column="product_sku_id"/>
        <result property="productName" column="product_name"/>
        <result property="productCover" column="product_cover"/>
        <result property="productPrice" column="product_price"/>
        <result property="quantity" column="quantity"/>
        <result property="totalPrice" column="total_price"/>
        <result property="commissionAmount" column="commission_amount"/>
        <result property="commissionType" column="commission_type"/>
        <result property="specs" column="specs"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findByOrderId" resultMap="OrderProductResultMap">
        SELECT * FROM order_products WHERE order_id = #{orderId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO order_products (order_id, product_id, product_sku_id, product_name,
                                    product_cover, product_price, quantity, total_price,
                                    commission_amount, commission_type, specs, created_at)
        VALUES (#{orderId}, #{productId}, #{productSkuId}, #{productName},
                #{productCover}, #{productPrice}, #{quantity}, #{totalPrice},
                #{commissionAmount}, #{commissionType}, #{specs}, #{createdAt})
    </insert>

</mapper>
